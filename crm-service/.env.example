# Port the CRM Express server will bind to
PORT=3000

# Connection URI for the MongoDB database instance (xeno_crm database name)
MONGODB_URI=mongodb://localhost:27017/xeno_crm

# JWT Secret string used to sign and verify user authentication tokens
JWT_SECRET=your_jwt_secret_here

# Groq API Key used to call the llama-3.3-70b-versatile completion model
GROQ_API_KEY=your_groq_api_key_here

# The base URL of the channel service simulator used to post campaign execution dispatches
CHANNEL_SERVICE_URL=http://localhost:4000
